# ===== Supabase =====  (project ref: orhsqnowvfbgnuosraxs)
SUPABASE_URL=https://orhsqnowvfbgnuosraxs.supabase.co
SUPABASE_ANON_KEY=                   # public key (Settings > API) — needed by frontend + still TODO
SUPABASE_SERVICE_ROLE_KEY=          # BACKEND ONLY — never expose to the frontend — still TODO
SUPABASE_DB_HOST=db.orhsqnowvfbgnuosraxs.supabase.co   # IPv6-only direct connection
SUPABASE_DB_PASSWORD=               # only for direct psql/admin (URL-encode spaces as %20 in a URL)

# ===== Backend / Inference (FastAPI on AWS) =====
INFERENCE_MODE=mock                 # mock | real   (mock for local dev; real on the GPU box)
MODEL_DIR=./ml/checkpoints
ALLOWED_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=50

# ===== Roboflow (SAM-3 + hosted detection models) =====
ROBOFLOW_API_KEY=                   # primary key
ROBOFLOW_API_KEY_FALLBACK=          # tried automatically if the primary hits a rate limit/quota

# ===== Frontend (Next.js) — PUBLIC (shipped to browser) =====
NEXT_PUBLIC_SUPABASE_URL=https://orhsqnowvfbgnuosraxs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_HERO_JOB_ID=                # pins a specific violation as the landing-page hero image; unset = most-recent
